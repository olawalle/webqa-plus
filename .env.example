# ── LLM Provider ──────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ── Optional: pre-set credentials users will see in the UI ────────────────
# Leave blank to let users supply credentials through the web form.
# WEBQA_DEFAULT_EMAIL=
# WEBQA_DEFAULT_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────
# These are consumed by docker-compose / the container.
# Do not change unless you also update docker-compose.yml.
PORT=8080
