# WebQA-Plus Configuration
# Powered by Gemini — Google's multimodal AI

# Gemini LLM Configuration
llm:
  provider: "gemini"
  api_key: "${GOOGLE_API_KEY}"  # Get yours at https://aistudio.google.com/apikey
  model: "gemini-2.0-flash"    # Options: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-pro-preview-03-25
  max_tokens: 4096
  temperature: 0.3
  multimodal: true              # Enables screenshot injection into prompts (vision-based QA)
  vertex_ai: false              # Set true to use Vertex AI endpoint instead of AI Studio

# Google Cloud Configuration (for Cloud Run deployment)
google_cloud:
  project_id: "${GCP_PROJECT_ID}"
  region: "us-central1"

# Playwright Configuration
playwright:
  browser: "chromium"
  viewport:
    width: 1920
    height: 1080
  timeout: 30000
  action_timeout: 5000

# MCP Configuration
mcp:
  server_url: "http://localhost:3000"
  timeout: 10000

# Testing Configuration
testing:
  max_steps: 200
  max_depth: 10
  screenshot_on_error: true
  screenshot_on_action: true
  dom_exploration_enabled: true
  hidden_menu_expander: true
  deep_traversal: true
  path_discovery_boost: 1
  form_validation_pass: true

# Cost Guardrails
cost:
  max_llm_calls: 500
  max_llm_tokens: 100000
  estimated_cost_per_1k_tokens: 0.01

# Report Configuration
report:
  template_dir: "src/webqa_plus/reporter"
  output_format: "pdf"
  include_screenshots: true
  include_console_logs: true
  include_network_logs: true

# Visual Mode Settings
visual:
  overlay_position: "bottom-right"
  overlay_opacity: 0.9
  update_interval_ms: 100
